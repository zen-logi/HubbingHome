@inherits LayoutComponentBase

<div class="app-shell">
    <header class="app-topbar">
        <div class="app-topbar-inner">
            <nav class="app-nav" aria-label="Primary">
                <NavLink href="/" Match="NavLinkMatch.All" class="app-nav-link" ActiveClass="active">
                    <span class="line-icon home-line" aria-hidden="true"></span>
                    <span>リモコン</span>
                </NavLink>
                <NavLink href="/settings" class="app-nav-link" ActiveClass="active">
                    <span class="line-icon settings-line" aria-hidden="true"></span>
                    <span>設定</span>
                </NavLink>
            </nav>

            <img class="app-logo" src="images/hubbinghome-wordmark.svg" alt="HubbingHome" />
        </div>
    </header>

    <main class="app-main">
        @Body
    </main>
</div>
