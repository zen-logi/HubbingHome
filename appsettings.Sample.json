{
  "HomeAssistant": {
    "BaseUrl": "https://home-assistant.example.invalid",
    "AccessToken": "CHANGE_ME_HOME_ASSISTANT_TOKEN",
    "RequestTimeoutSeconds": 10,
    "AllowInsecureHttp": false
  },
  "Security": {
    "DeviceTokens": [
      "CHANGE_ME_DEVICE_TOKEN"
    ]
  },
  "RemoteControl": {
    "Rooms": [
      {
        "Id": "living",
        "Name": "Living Room",
        "RemoteEntityId": "remote.example_living_broadlink",
        "Devices": [
          {
            "Id": "living-light",
            "Name": "Living Light",
            "Kind": "light",
            "Commands": [
              {
                "Id": "on",
                "Name": "On",
                "Kind": "power",
                "Icon": "lightbulb",
                "ServiceDomain": "remote",
                "ServiceName": "send_command",
                "HomeAssistantCommand": "example_living_light_on",
                "Data": {}
              },
              {
                "Id": "off",
                "Name": "Off",
                "Kind": "power",
                "Icon": "power",
                "ServiceDomain": "remote",
                "ServiceName": "send_command",
                "HomeAssistantCommand": "example_living_light_off",
                "Data": {}
              }
            ]
          },
          {
            "Id": "living-ac",
            "Name": "Living Air Conditioner",
            "Kind": "airConditioner",
            "Commands": [
              {
                "Id": "temperature",
                "Name": "Temperature",
                "Kind": "temperature",
                "Icon": "thermometer",
                "ServiceDomain": "remote",
                "ServiceName": "send_command",
                "HomeAssistantCommandParameter": "homeAssistantCommand",
                "HomeAssistantCommandPattern": "^(cool_(22_[05]|23_[05]|24_[05]|25_[05]|26_[05]|27_[05]|28_0)|heat_(18_[05]|19_[05]|20_[05]|21_[05]|22_[05]|23_0))$",
                "HomeAssistantCommandGenerator": "daikin_air_conditioner",
                "Data": {}
              }
            ]
          }
        ]
      }
    ]
  }
}
