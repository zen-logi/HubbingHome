root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.{cs,csx,fs,fsx,vb}]
indent_style = space
indent_size = 4

[*.{json,jsonc,js,jsx,ts,tsx,css,scss,html,xml,yml,yaml}]
indent_style = space
indent_size = 2

[*.md]
indent_style = space
indent_size = 2
trim_trailing_whitespace = false

[*.slnx]
indent_style = space
indent_size = 2
